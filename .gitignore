# Cargo build output
/target/
fuzz/target/

# Cargo.lock is committed.  gitway-cli is a binary (committing the lockfile
# is the convention) and the workspace pins `anvil-ssh` and a long
# transitive dep tree -- the committed lockfile is what makes builds
# reproducible across CI runners.  The in-tree `gitway-lib/` shim is
# `publish = false` and inherits the workspace lockfile too.

# Editor and IDE artifacts
.idea/
.vscode/
*.iml
*.swp
*.swo
*~
.DS_Store

# Claude Code per-project config and local state.  These live under the
# project directory so the harness can scope settings, hooks, permissions,
# and plans per-repo, but they are user-/machine-specific and must not be
# checked in.  See https://docs.claude.com/en/docs/claude-code/settings.
.claude/

# Nix
result
result-*
.direnv/

# Shell session files
*.txt.bak

# Exported conversation files (Claude Code /export output)
2026-*.txt
Chat.txt
Chat-*.txt

# Criterion benchmark output
criterion/

# cargo-fuzz corpus and artifacts (keep the fuzz targets, not the generated data)
fuzz/corpus/
fuzz/artifacts/
fuzz/coverage/

# cargo-geiger output
geiger/

# Temporary files
*.tmp
*.bak
