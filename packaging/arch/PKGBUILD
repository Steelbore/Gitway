# gitway-bin — installs the pre-built static musl binary from the GitHub
# Release page.  This is the recommended package for most users.
#
# To build from source instead, use the companion PKGBUILD-git.

pkgname=gitway-bin
pkgver=0.3.0
pkgrel=1
pkgdesc="Purpose-built SSH transport client for Git hosting services (GitHub, GitLab, Codeberg)"
arch=('x86_64')
url="https://github.com/steelbore/gitssh"
license=('GPL-3.0-or-later')
provides=('gitway')
conflicts=('gitway' 'gitway-git')

source=(
  "${pkgname}-${pkgver}.tar.gz::https://github.com/steelbore/gitssh/releases/download/v${pkgver}/gitway-v${pkgver}-linux-x86_64.tar.gz"
)
# Update sha256sums by running: updpkgsums
# or manually:  sha256sum gitway-bin-${pkgver}.tar.gz
sha256sums=('SKIP')

package() {
  cd "${srcdir}"

  install -Dm755 gitway          "${pkgdir}/usr/bin/gitway"
  install -Dm644 README.md       "${pkgdir}/usr/share/doc/${pkgname}/README.md"
  install -Dm644 LICENSE         "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
